# Secrets / environment
.env
.env.*
!.env.example
*.secret

# TLS material (issued at deploy time; never commit)
certs/
letsencrypt/
*.pem
*.key
*.crt

# Build artifacts produced by `make` (sources live in the component repos).
# The provided AWS SDK RPMs under rpms/aws-sdk/ are inputs and stay tracked.
rpms/fileengine/*.rpm
images/nginx/spa/*
!images/nginx/spa/.gitkeep
init/migrations/*.sql
!init/migrations/.gitkeep
images/csai/build-src/

# Runtime data / volumes
data/
volumes/
*.sqlite
*.db

# Logs
*.log
logs/

# IDE / editor
.idea/
.vscode/
*.swp
*~

# OS cruft
.DS_Store
Thumbs.db
