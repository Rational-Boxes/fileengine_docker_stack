# Unified FileEngine stack — environment.
#
# Copy to `.env` and fill in. `.env` is gitignored (holds secrets). This file
# grows as later phases add services; Phase 2 covers the data layer + core.
# No secrets are auto-generated — set them all here.

# --- Stack release version --------------------------------------------------
# Tags the built images (fileengine-*:$VERSION) and must match the base image
# built by `make base-image`. Keep in sync with the Makefile's VERSION default.
VERSION=1.1.0

# --- Domain & TLS (nginx) ---------------------------------------------------
# Apex domain the tenants are served under: <tenant>.<base> (SPA + /api,/csai,/mcp)
# and <tenant>-drive.<base> (WebDAV). Point a wildcard DNS A record *.<base> -> IP.
BASE_DOMAIN=example.com
# TLS_MODE: none (UNSECURED HTTP — testing only) | selfsigned (dev) |
#           letsencrypt-dns (automated DNS-01) | letsencrypt-manual | byo
TLS_MODE=letsencrypt-dns
# Let's Encrypt (letsencrypt-* modes):
LE_EMAIL=admin@example.com
LE_STAGING=false
# letsencrypt-dns only — DNS provider for the DNS-01 challenge (cloudflare|route53).
# Provide the provider creds: cloudflare -> mount /etc/letsencrypt/dns.ini;
# route53 -> AWS_* in the environment.
LE_DNS_PROVIDER=cloudflare
# Max upload body size proxied to the bridge (0 = unlimited).
HTTP_MAX_BODY_BYTES=0

# --- MCP server (tool-exposure policy) -------------------------------------
MCP_READ_ONLY=0
MCP_ALLOW_DELETE=0

# --- Postgres (shared by core + CSAI) --------------------------------------
POSTGRES_USER=fileengine
POSTGRES_PASSWORD=change-me-postgres
# Database names. CORE_DB is created by the postgres image; db-init creates CSAI_DB.
CORE_DB=fileengine
CSAI_DB=convert_search_ai

# --- Redis (core event stream + CSAI cache invalidation) -------------------
REDIS_PASSWORD=change-me-redis

# --- Object store (external S3) --------------------------------------------
# Point at your S3-compatible endpoint. For LOCAL testing, the
# docker-compose.test.yml override provides a MinIO and sets these for you.
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=fileengine
S3_ACCESS_KEY=change-me-access
S3_SECRET_KEY=change-me-secret
S3_PATH_STYLE=true

# --- Core at-rest crypto ----------------------------------------------------
# In production keep ENCRYPT on and AT_REST_KEY STABLE — losing the key makes
# stored data unreadable. (The test override sets ENCRYPT=false to avoid key setup.)
FILEENGINE_ENCRYPT_DATA=true
FILEENGINE_COMPRESS_DATA=true
AT_REST_KEY=change-me-32-byte-key-keep-stable

# --- LDAP (389 Directory Server) — auth + tenant/role groups ----------------
# LDAP_DOMAIN is the directory suffix (derive from BASE_DOMAIN, e.g. host.com ->
# dc=host,dc=com). The bridges + MCP bind as LDAP_BIND_DN to search, then bind as
# the user to authenticate. For now the bind account is the Directory Manager
# (root) whose password is also the instance DM password — see LDAP-3 to switch
# to a least-privilege bind account.
LDAP_ENDPOINT=ldap://ldap:3389
LDAP_DOMAIN=dc=example,dc=com
LDAP_BIND_DN=cn=Directory Manager
LDAP_BIND_PASSWORD=change-me-ldap
LDAP_TENANT_BASE=ou=tenants,dc=example,dc=com
LDAP_USER_BASE=ou=users,dc=example,dc=com
# Initial administrative user (seeded into all role groups of the default tenant).
LDAP_ADMIN_EMAIL=admin@example.com
LDAP_ADMIN_PASSWORD=change-me-admin
# Default tenant name (an OU under ou=tenants). No hyphens (see WebDAV routing).
DEFAULT_TENANT=default

# --- http-bridge tunables ---------------------------------------------------
# Extra CORS origins (same-origin behind nginx needs none). Max upload body bytes.
HTTP_CORS_ORIGIN=
HTTP_MAX_BODY_BYTES=104857600

# --- CSAI / AI providers (independent embedder + chat) ----------------------
# Embeddings run on the bundled CPU Ollama; chat targets an external provider.
# The two are fully independent (separate provider/model/endpoint/key).
CSAI_EMBEDDING_PROVIDER=ollama
CSAI_EMBEDDING_MODEL=nomic-embed-text
CSAI_EMBEDDING_BASE_URL=http://ollama:11434/v1
# Dimension MUST match the embedding model (nomic-embed-text = 768). Drives the
# pgvector column width when tenants are provisioned; changing it later requires
# re-provisioning + re-embedding.
CSAI_EMBEDDING_DIMENSION=768
# Chat: anthropic (default) | openai | ollama | openai-compatible | echo
CSAI_CHAT_PROVIDER=anthropic
CSAI_CHAT_MODEL=claude-sonnet-4-6
CSAI_CHAT_BASE_URL=
CSAI_CHAT_API_KEY=
ANTHROPIC_API_KEY=
# Extra CORS origins for the CSAI app (same-origin behind nginx needs none).
CSAI_CORS_ORIGINS=
# Build the CSAI image with docling (heavy ML PDF backend). 1=include (default,
# best fidelity), 0=omit (smaller/faster; chain still works via the others).
INSTALL_DOCLING=1
